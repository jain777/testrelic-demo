<%- include('partials/header', { title: title, cartCount: cartCount, user: user }) %>

<section class="container section">
  <h1 class="page-title">My Profile</h1>

  <div class="profile-layout">
    <div class="profile-info-card">
      <h2>Account Information</h2>
      <div class="profile-field">
        <span class="profile-label">Name:</span>
        <span><%= user.name %></span>
      </div>
      <div class="profile-field">
        <span class="profile-label">Email:</span>
        <span><%= user.email %></span>
      </div>
      <button class="btn btn-outline" disabled>Edit Profile</button>
    </div>

    <div class="profile-orders">
      <h2>Order History</h2>
      <% if (userOrders.length === 0) { %>
        <div class="empty-state">
          <p>No orders yet.</p>
          <a href="/products" class="btn btn-outline">Start Shopping</a>
        </div>
      <% } else { %>
        <table class="orders-table">
          <thead>
            <tr>
              <th>Order ID</th>
              <th>Date</th>
              <th>Items</th>
              <th>Total</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% userOrders.forEach(order => { %>
              <tr>
                <td><a href="/order-confirmation/<%= order.id %>">#<%= order.id %></a></td>
                <td><%= new Date(order.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %></td>
                <td><%= order.items.reduce((sum, item) => sum + item.quantity, 0) %> item(s)</td>
                <td>$<%= order.total.toFixed(2) %></td>
                <td><span class="status-badge status-confirmed"><%= order.status %></span></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
