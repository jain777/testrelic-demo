<%- include('partials/header', { title: title, cartCount: cartCount, user: user }) %>

<section class="container section">
  <div class="auth-container">
    <h1 class="auth-title">Sign In</h1>

    <% if (error) { %>
      <div class="error-message"><%= error %></div>
    <% } %>

    <form action="/login" method="POST" class="auth-form">
      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" placeholder="you@example.com" required class="form-input">
      </div>
      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" placeholder="Enter your password" required class="form-input">
      </div>
      <button type="submit" class="btn btn-primary btn-block">Sign In</button>
    </form>

    <p class="auth-footer">
      Don't have an account? <a href="/signup">Sign Up</a>
    </p>
  </div>
</section>

<%- include('partials/footer') %>
