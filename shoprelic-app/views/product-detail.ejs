<%- include('partials/header', { title: title, cartCount: cartCount, user: user }) %>

<section class="container section">
  <a href="/products" class="back-link">&larr; Back to Catalog</a>

  <div class="product-detail">
    <div class="product-detail-image">
      <img src="<%= product.image %>" alt="<%= product.name %>">
    </div>
    <div class="product-detail-info">
      <span class="category-badge"><%= product.category %></span>
      <h1 class="product-detail-title"><%= product.name %></h1>
      <div class="product-detail-rating">
        <span class="stars">
          <% for (let i = 1; i <= 5; i++) { %>
            <% if (i <= Math.floor(product.rating)) { %>
              &#9733;
            <% } else if (i - 0.5 <= product.rating) { %>
              &#9733;
            <% } else { %>
              &#9734;
            <% } %>
          <% } %>
        </span>
        <span class="review-count"><%= product.rating %> out of 5 (<%= product.reviewCount %> reviews)</span>
      </div>
      <p class="product-detail-price">$<%= product.price.toFixed(2) %></p>
      <p class="product-detail-description"><%= product.description %></p>

      <form action="/cart/add" method="POST" class="add-to-cart-form">
        <input type="hidden" name="productId" value="<%= product.id %>">
        <div class="quantity-group">
          <label for="quantity">Quantity:</label>
          <input type="number" id="quantity" name="quantity" value="1" min="1" max="99" class="quantity-input">
        </div>
        <button type="submit" class="btn btn-primary btn-lg">Add to Cart</button>
      </form>
    </div>
  </div>

  <div class="reviews-section">
    <h2>Customer Reviews (<%= product.reviews.length %>)</h2>
    <% product.reviews.forEach(review => { %>
      <div class="review-card">
        <div class="review-header">
          <strong class="review-author"><%= review.author %></strong>
          <span class="stars">
            <% for (let i = 1; i <= 5; i++) { %>
              <% if (i <= review.rating) { %>
                &#9733;
              <% } else { %>
                &#9734;
              <% } %>
            <% } %>
          </span>
        </div>
        <p class="review-text"><%= review.text %></p>
      </div>
    <% }) %>
  </div>
</section>

<%- include('partials/footer') %>
